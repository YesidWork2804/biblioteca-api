{
  "info": {
    "name": "Biblioteca API",
    "description": "Colección de endpoints para el sistema de gestión de biblioteca",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Yesid Dev\",\n  \"email\": \"yesid@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Tiene token', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.token).to.exist;",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"yesid@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiene token', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.token).to.exist;",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Devuelve datos del usuario', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.email).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Libros",
      "item": [
        {
          "name": "Listar libros",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/libros?titulo=&anio=&autor_id=&page=1",
              "host": ["{{base_url}}"],
              "path": ["libros"],
              "query": [
                {"key": "titulo", "value": ""},
                {"key": "anio", "value": ""},
                {"key": "autor_id", "value": ""},
                {"key": "page", "value": "1"}
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiene estructura data y meta', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data).to.be.an('array');",
                  "  pm.expect(json.meta).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Obtener libro por ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/libros/1",
              "host": ["{{base_url}}"],
              "path": ["libros", "1"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Incluye autores', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.autores).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Crear libro",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/libros",
              "host": ["{{base_url}}"],
              "path": ["libros"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"El Principito\",\n  \"isbn\": \"978-0156012197\",\n  \"anio_publicacion\": 1943,\n  \"numero_paginas\": 96,\n  \"descripcion\": \"Filosofía para niños\",\n  \"stock_disponible\": 5,\n  \"autores\": [1, 2]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Libro creado con ID', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.id).to.exist;",
                  "  pm.collectionVariables.set('libro_id', json.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Actualizar libro",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/libros/1",
              "host": ["{{base_url}}"],
              "path": ["libros", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Cien años de soledad (Edición actualizada)\",\n  \"stock_disponible\": 10\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Eliminar libro (soft delete)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/libros/1",
              "host": ["{{base_url}}"],
              "path": ["libros", "1"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Préstamos",
      "item": [
        {
          "name": "Listar préstamos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/prestamos?estado=&page=1",
              "host": ["{{base_url}}"],
              "path": ["prestamos"],
              "query": [
                {"key": "estado", "value": ""},
                {"key": "page", "value": "1"}
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Cada préstamo tiene libro y usuario', () => {",
                  "  const json = pm.response.json();",
                  "  if (json.data.length > 0) {",
                  "    pm.expect(json.data[0].libro).to.exist;",
                  "    pm.expect(json.data[0].usuario).to.exist;",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Crear préstamo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/prestamos",
              "host": ["{{base_url}}"],
              "path": ["prestamos"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario_id\": 1,\n  \"libro_id\": 2,\n  \"fecha_prestamo\": \"2026-06-19\",\n  \"fecha_devolucion_estimada\": \"2026-07-04\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Préstamo creado con ID', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.id).to.exist;",
                  "  pm.collectionVariables.set('prestamo_id', json.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Devolver préstamo",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/prestamos/1/devolver",
              "host": ["{{base_url}}"],
              "path": ["prestamos", "1", "devolver"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Estado es devuelto', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.estado).to.eql('devuelto');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Casos de error",
      "item": [
        {
          "name": "Login con credenciales inválidas",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"noexiste@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
