            }
          ]
        },
        {
          "name": "Crear libro con datos inválidos",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/libros",
              "host": ["{{base_url}}"],
              "path": ["libros"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"\",\n  \"isbn\": \"\",\n  \"anio_publicacion\": 1900,\n  \"stock_disponible\": -1\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('Tiene errores de validación', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.errors).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Acceso sin token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/libros",
              "host": ["{{base_url}}"],
              "path": ["libros"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
